# Copy to .env and edit

# --- Paths ---
KNOWLEDGE_DIR=./knowledge
CHROMA_DIR=./data/chroma
COLLECTION_NAME=engineer_knowledge

# --- Embedding ---
EMBED_MODEL=BAAI/bge-m3
EMBED_BATCH=256

# --- Chunking ---
CHUNK_SIZE=600
CHUNK_OVERLAP=80
TOP_K=5

# --- Retrieval ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
OVERFETCH_FACTOR=6

# --- LLM ---
LLM_PROVIDER=openai
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-groq-api-key

# --- Fallback LLM (parametric knowledge when RAG fails) ---
# FALLBACK_PROVIDER=openai
# FALLBACK_MODEL=gemini-2.5-flash
# FALLBACK_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
# FALLBACK_API_KEY=your-gemini-key

# --- Security (leave empty for dev mode = no auth) ---
# API_KEYS=key1,key2,key3
# In Docker, use secrets instead of env vars for sensitive values:
#   mkdir secrets && echo "your-key" > secrets/LLM_API_KEY
# RATE_LIMIT_RPM=60
# RATE_LIMIT_BURST=10
# MAX_QUERY_LENGTH=2000
# MAX_TOP_K=20
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# --- Ollama (only if LLM_PROVIDER=ollama) ---
OLLAMA_URL=http://localhost:11434

# --- Observability ---
# LOG_FORMAT=json          # "json" for production, "text" for dev (default: text)

# --- Concurrency ---
WORKERS=8
